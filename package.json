{
    "name": "anyfork-web-docs",
    "version": "1.0.0",
    "private": true,
    "description": "基于 Vite + Vue + TypeScript 构建的企业级Vue管理后台前端通用项目，集成 Nuxt UI、Pinia、VueRouter、Tailwind CSS、Alova 等核心技术，并通过 ESLint、Prettier、stylelint 保障代码规范，结合 husky、lint-staged、commitlint、commitizen、cz-git、conventional-changelog 实现提交规范与自动化日志生成，符合企业级项目开发标准。",
    "author": {
        "name": "anyfork",
        "email": "anyfork@gmail.com"
    },
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "build:cloudflare": "cross-env NITRO_PRESET=cloudflare_pages_static nuxt build",
        "build:netlify": "cross-env NITRO_PRESET=netlify-static nuxt build",
        "changelog": "conventional-changelog -p commitlint.config.js -i CHANGELOG.md -s",
        "changelog:all": "conventional-changelog -p commitlint.config.js -i CHANGELOG.md -s -r 0",
        "commit": "git add . && git cz",
        "deploy:cloudflare": "wrangler pages deploy dist",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:staged": "lint-staged",
        "lint:style": "stylelint  '**/*.{css,vue}' --fix",
        "lint:style:fix": "stylelint '**/*.{css,vue}' --fix",
        "prepare": "simple-git-hooks",
        "prettier": "prettier --write .",
        "preview": "nuxt preview",
        "preview:cloudflare": "wrangler pages dev dist",
        "preview:netlify": "pnpm dlx serve dist"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm run lint:staged",
        "commit-msg": "pnpm exec commitlint --edit $1"
    },
    "lint-staged": {
        "*.{js,ts,mjs,mts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{cjs,json,jsonc}": [
            "prettier --write"
        ],
        "*.vue": [
            "eslint --fix",
            "stylelint --fix --allow-empty-input",
            "prettier --write"
        ],
        "*.{html,htm}": [
            "prettier --write"
        ],
        "*.{scss,css,less}": [
            "stylelint --fix --allow-empty-input",
            "prettier --write"
        ],
        "*.{md,mdx}": [
            "prettier --write"
        ],
        "*.{yaml,yml}": [
            "prettier --write"
        ]
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-git"
        }
    },
    "dependencies": {
        "@docsearch/css": "^4.6.0",
        "@docsearch/js": "^4.6.0",
        "@nuxt/ui": "^4.5.1",
        "@nuxtjs/algolia": "^1.11.2",
        "@nuxtjs/device": "^4.0.0",
        "@vueuse/nuxt": "^14.2.1",
        "@waline/client": "^3.13.0",
        "animate.css": "^4.1.1",
        "crypto-js": "^4.2.0",
        "dayjs-nuxt": "^2.1.11",
        "nuxt": "^4.3.1",
        "tailwindcss": "^4.2.1",
        "typed.js": "^3.0.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@nuxt/eslint": "^1.15.2",
        "@types/crypto-js": "^4.2.2",
        "@types/node": "^22.19.14",
        "commitizen": "^4.3.1",
        "conventional-changelog-cli": "^5.0.0",
        "cross-env": "^10.1.0",
        "cz-git": "^1.12.0",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "lint-staged": "^16.3.2",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^3.0.2",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "simple-git-hooks": "^2.13.1",
        "stylelint": "^17.4.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-recess-order": "^7.6.1",
        "stylelint-config-recommended-vue": "^1.6.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^7.0.1",
        "typescript": "^5.9.3",
        "vite-plugin-eslint2": "^5.0.5",
        "vue-tsc": "^3.2.5"
    },
    "engines": {
        "node": ">=24.9.0",
        "pnpm": ">=10.28.0"
    },
    "pnpm": {
        "ignoredBuiltDependencies": [
            "@parcel/watcher",
            "esbuild",
            "unrs-resolver",
            "vue-demi"
        ]
    }
}
